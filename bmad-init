#!/bin/bash

# Color configuration for terminal output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo -e "${BLUE}=== Initializing BMAD-METHOD ===${NC}"

# Check for Node and NPX
if ! command -v node &> /dev/null || ! command -v npx &> /dev/null; then
    echo -e "${RED}Error: Node.js and npx must be installed to continue.${NC}"
    exit 1
fi

# Load configuration
CONFIG_FILE="$HOME/.bmad-init-rc"
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
else
    BMAD_TOOLS="antigravity"
    AUTO_GIT_INIT="Y"
    GIT_NAME=""
    GIT_EMAIL=""
fi

# 1. BMAD Installation
echo -e "${GREEN}[1/4] Installing BMAD-METHOD (Tools: $BMAD_TOOLS)...${NC}"
npx bmad-method install --directory . --modules bmm --tools "$BMAD_TOOLS" --yes

if [ $? -ne 0 ]; then
    echo -e "${RED}Error: BMAD installation failed.${NC}"
    exit 1
fi

# 2. Git repository initialization
if [[ "$AUTO_GIT_INIT" =~ ^[Yy]$ ]]; then
    if [ ! -d ".git" ]; then
        echo -e "${GREEN}[2/4] Initializing Git repository...${NC}"
        git init
    else
        echo -e "${BLUE}[2/4] Git repository already exists, skipping.${NC}"
    fi

    # 3. Git configuration
    echo -e "${GREEN}[3/4] Configuring Git identity...${NC}"
    if [ -n "$GIT_NAME" ]; then
        git config user.name "$GIT_NAME"
    fi
    if [ -n "$GIT_EMAIL" ]; then
        git config user.email "$GIT_EMAIL"
    fi

    # 4. Add and Commit
    echo -e "${GREEN}[4/4] Adding files and creating commit...${NC}"
    # Only add folders created by BMAD-METHOD and omit other project files
    git add .agent _bmad _bmad-output 2>/dev/null
    git commit -m "chore: Init project with BMAD-METHOD"
else
    echo -e "${BLUE}Skipping Git initialization as per configuration.${NC}"
fi

echo -e "${BLUE}=== Done! BMAD-METHOD is ready in this workspace. ===${NC}"
